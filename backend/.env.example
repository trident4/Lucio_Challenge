# Mac Studio OpenAI-compatible API
MAC_STUDIO_BASE_URL=http://your-mac-studio-ip:port/v1
MAC_STUDIO_API_KEY=not-needed

# OpenRouter (Leave API_KEY blank to use local Mac Studio for LLM)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Models
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_MODEL=qwen/qwen3-30b-a3b-2507

# Embedding provider: "mac_studio" (default) or "openrouter"
# Set to "openrouter" to route embeddings through OpenRouter instead of Mac Studio
EMBEDDING_PROVIDER=mac_studio

# Tuning
# Dimension reduction via Matryoshka encoding. Rule of thumb: keep within ~3x of native dims.
# text-embedding-3-large (3072d native) → 1024; nomic-embed-text-v1.5 (768d native) → 256
EMBEDDING_DIMENSIONS=1024
BM25_TOP_K=150
RERANK_TOP_K=8
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.0
# Max items per embedding API call
EMBEDDING_BATCH_SIZE=100
# Max concurrent embedding API calls
EMBEDDING_CONCURRENCY=5
